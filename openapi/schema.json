  "components": {
    "schemas": {
      "CreateGroup": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "GroupInfo": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "GroupMembers": {
        "type": "object",
        "required": [
          "members"
        ],
        "properties": {
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserInfo"
            }
          }
        }
      },
      "ModifyMember": {
        "type": "object",
        "required": [
          "member"
        ],
        "properties": {
          "member": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "ObjectPermissions": {
        "type": "object",
        "required": [
          "name",
          "actions"
        ],
        "properties": {
          "actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "name": {
            "type": "string"
          }
        }
      },
      "PermissionRef": {
        "type": "object",
        "required": [
          "object",
          "action"
        ],
        "properties": {
          "action": {
            "type": "string"
          },
          "object": {
            "type": "string"
          }
        }
      },
      "ProviderInfo": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "UserInfo": {
        "type": "object",
        "required": [
          "id",
          "email",
          "name"
        ],
        "properties": {
          "email": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "user",
      "description": "Users"
    },
    {
      "name": "auth",
      "description": "Auth"
    },
    {
