        "tags": [
          "auth"
        ],
        "summary": "List authentication providers.",
        "operationId": "list_providers",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProviderInfo"
                  }
                }
              }
            }
          }
        }
      }
    },
