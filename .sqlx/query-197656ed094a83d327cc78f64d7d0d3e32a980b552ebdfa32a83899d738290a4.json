  "query": "\n            SELECT\n                users.id, users.email, users.name, users.is_admin\n            FROM user_identities\n            JOIN users ON user_identities.user_id = users.id\n            WHERE\n                user_identities.provider = $1\n                AND user_identities.provider_id = $2;\n            ",
